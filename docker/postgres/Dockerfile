# syntax=docker/dockerfile:1

########################################
# PostgreSQL
########################################
# Alpine-вариант — минимальный размер образа.
# Мажорную версию фиксируем явно, чтобы обновление базы
# было осознанным шагом, а не сюрпризом при пересборке.
FROM postgres:17-alpine

# Дефолты на случай запуска без переменных окружения.
# В compose они переопределяются значениями из .env / окружения.
ENV POSTGRES_DB=task_manager \
    POSTGRES_USER=postgres \
    POSTGRES_PASSWORD=password

# Сюда можно класть *.sql / *.sh скрипты инициализации —
# официальный образ выполнит их при первом старте (на пустом volume).
# COPY init/ /docker-entrypoint-initdb.d/

EXPOSE 5432